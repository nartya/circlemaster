{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "circlemaster",
  "compatibility_date": "2026-04-12",
  "observability": {
    "enabled": true
  },

  "main": "src/index.js",
  "assets": {
    "directory": "join",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}